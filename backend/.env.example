APP_ENV=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/maze
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_TOKEN_TTL_MINUTES=10080
PUBLIC_API_BASE_URL=http://127.0.0.1:8000
DEFAULT_PLAN_ID=
SCREENSHOT_STORAGE_DIR=./storage/screenshots
SCREENSHOT_SIGNED_URL_TTL_SECONDS=300
SCREENSHOT_OBJECT_TTL_SECONDS=172800
SCREENSHOT_MAX_UPLOAD_BYTES=2097152
SCREENSHOT_SIGNING_SECRET=replace-with-a-long-random-secret
