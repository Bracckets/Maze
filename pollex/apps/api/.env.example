APP_NAME="Pollex Tactus API"
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://postgres:CHANGE_ME@127.0.0.1:5432/pollex
AUTO_CREATE_DATABASE=true
AUTO_CREATE_TABLES=true
STUDIO_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

TACTUS_LLM_PROVIDER=none
TACTUS_LLM_MODEL=gpt-5-nano
TACTUS_LLM_TIMEOUT_SECONDS=4
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OLLAMA_BASE_URL=http://127.0.0.1:11434
