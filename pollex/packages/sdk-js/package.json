{
  "name": "@pollex/sdk-js",
  "version": "0.2.0",
  "description": "Framework-agnostic TypeScript client for Pollex Tactus.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pollex/shared-types": "0.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "vite-plugin-dts": "^4.4.0"
  }
}
