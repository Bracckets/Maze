{
  "name": "@pollex/sdk",
  "version": "0.1.0",
  "description": "Browser SDK for Pollex telemetry and Liquid runtime resolution.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "pollex",
    "analytics",
    "telemetry",
    "liquid",
    "sdk",
    "browser"
  ],
  "dependencies": {
    "html2canvas": "^1.4.1"
  },
  "devDependencies": {
    "jsdom": "^26.1.0",
    "tsup": "^8.3.5",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
